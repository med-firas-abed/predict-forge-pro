# ── Supabase (required) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ── AI — Chat, Planner, Reports (Groq LLM) ──
GROQ_API_KEY=gsk_...

# ── Email alerts (optional — emails skipped without it) ──
RESEND_API_KEY=re_...
ADMIN_EMAIL=your-email@example.com

# ── MQTT (optional — leave empty for simulated mode) ──
MQTT_BROKER=
MQTT_PORT=8883
MQTT_USER=
MQTT_PASSWORD=
MQTT_USE_SSL=true

# ── CORS (comma-separated origins) ──
# For local dev, add: http://localhost:5173,http://localhost:8080
CORS_ORIGINS=https://prediteq.vercel.app

# ── Frontend URL (used in email links) ──
DASHBOARD_URL=https://prediteq.vercel.app

# ── ML directory (auto-detected locally, set on Render) ──
# ML_DIR=/opt/render/project/src/prediteq_ml
